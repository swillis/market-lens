# Set to "true" to use mock data (no API keys needed)
# Set to "false" or remove to use real API data
USE_MOCK_DATA=true

# Anthropic API key for AI-generated explanations
# Get a key at: https://console.anthropic.com/settings/keys
# Uses claude-sonnet-4-20250514
ANTHROPIC_API_KEY=

# Financial Modeling Prep — prices, company profiles, peer quotes
# Get a free key at: https://financialmodelingprep.com/developer/docs
# Free tier: 250 requests/day
FMP_API_KEY=

# Finnhub — company news, peer identification
# Get a free key at: https://finnhub.io/register
# Free tier: 60 calls/minute
FINNHUB_API_KEY=

# Upstash Redis — persistent NarrativeSnapshot storage (production only)
# Add the Upstash Redis integration in the Vercel Marketplace, then copy the
# auto-injected values here for local testing (optional — leave blank to use
# the disk-backed dev store instead, which requires no credentials).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
